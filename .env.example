# Anthropic API Key — wird erst in Phase 2 (apps/api) verwendet.
# Niemals client-seitig (apps/web) einbinden, niemals echten Key in diese Datei.
# Echte Werte gehören in .env (gitignored).
ANTHROPIC_API_KEY=sk-ant-...

# Modell-Override (optional, Default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Backend (Phase 2+)
PORT=3000
NODE_ENV=development

# CORS-Origin für Frontend in Dev
CORS_ORIGIN=http://localhost:5173

# SQLite-Datenbank (Phase 2+)
DATABASE_URL=file:./data/app.db
